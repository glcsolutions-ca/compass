{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": ".",
    "outDir": "dist-types",
    "baseUrl": ".",
    "paths": {
      "~/*": ["./src/*"],
      "@compass/contracts": ["../../packages/contracts/src/index.ts"],
      "@compass/runtime-protocol": ["../../packages/runtime-protocol/src/index.ts"],
      "@compass/testing": ["../../packages/testing/src/index.ts"]
    }
  },
  "references": [
    {
      "path": "../../packages/contracts"
    },
    {
      "path": "../../packages/runtime-protocol"
    }
  ],
  "include": ["src/**/*.ts", "test/integration/**/*.ts"]
}
