{
  "name": "@compass/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/main/index.ts",
    "lint": "eslint . --ext .ts --max-warnings=0",
    "test": "vitest run --config vitest.config.mts --passWithNoTests",
    "typecheck": "tsc -p tsconfig.ref.json --noEmit"
  },
  "dependencies": {
    "@compass/client-app": "workspace:*",
    "electron": "^37.2.6"
  },
  "devDependencies": {
    "@types/node": "^22",
    "tsx": "4.21.0",
    "vitest": "3.2.4"
  }
}
