{
  "extends": "../../tsconfig.base.json",
  "include": ["**/*", "**/.server/**/*", "**/.client/**/*", ".react-router/types/**/*"],
  "compilerOptions": {
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "types": ["node", "vite/client"],
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "rootDirs": [".", "./.react-router/types"],
    "baseUrl": ".",
    "paths": {
      "~/*": ["../../packages/app-shell/src/*"],
      "@compass/app-shell": ["../../packages/app-shell/src/index.ts"],
      "@compass/app-shell/*": ["../../packages/app-shell/src/*"],
      "@compass/contracts": ["../../packages/contracts/src/index.ts"],
      "@compass/sdk": ["../../packages/sdk/src/index.ts"],
      "@compass/shared": ["../../packages/shared/src/index.ts"],
      "@compass/shared/*": ["../../packages/shared/src/*"],
      "@compass/ui": ["../../packages/ui/src/index.ts"],
      "@compass/ui/*": ["../../packages/ui/src/*"]
    },
    "esModuleInterop": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "composite": true
  }
}
