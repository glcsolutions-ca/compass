{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "dist-types",
    "rootDir": "../.."
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "react-router.config.ts",
    "vite.config.ts",
    "../../packages/contracts/src/**/*.ts",
    "../../packages/sdk/src/**/*.ts",
    "../../packages/ui/src/**/*.ts",
    "../../packages/ui/src/**/*.tsx"
  ],
  "exclude": [
    "app/**/*.test.ts",
    "app/**/*.test.tsx",
    "../../packages/ui/src/**/*.test.ts",
    "../../packages/ui/src/**/*.test.tsx",
    "../../packages/contracts/src/**/*.test.ts",
    "../../packages/contracts/src/**/*.test.tsx",
    "../../packages/sdk/src/**/*.test.ts",
    "../../packages/sdk/src/**/*.test.tsx"
  ]
}
