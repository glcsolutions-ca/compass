{
  "name": "compass-platform",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22 <23"
  },
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "prepare": "node platform/scripts/dev/install-git-hooks.mjs",
    "build": "turbo run build",
    "clean": "rimraf --glob .turbo coverage \"*.tsbuildinfo\" \"apps/*/dist\" \"apps/*/dist-types\" \"apps/*/.next\" \"apps/*/.turbo\" \"apps/*/coverage\" \"apps/*/*.tsbuildinfo\" \"packages/*/dist\" \"packages/*/dist-types\" \"packages/*/.next\" \"packages/*/.turbo\" \"packages/*/coverage\" \"packages/*/*.tsbuildinfo\"",
    "dev": "node scripts/dev.mjs",
    "dev:desktop": "node scripts/dev-desktop.mjs",
    "dev:up": "node scripts/dev-up.mjs",
    "dev:down": "node scripts/dev-down.mjs",
    "env:setup": "node scripts/env-setup.mjs",
    "env:doctor": "node scripts/env-doctor.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "turbo run lint -- --max-warnings=0",
    "typecheck": "turbo run typecheck",
    "verify": "node scripts/verify.mjs",
    "verify:static": "node platform/pipeline/stages/01-commit-stage/scripts/run-static-analysis.mjs",
    "verify:unit": "node platform/pipeline/stages/01-commit-stage/scripts/run-unit-tests.mjs",
    "verify:integration": "node platform/pipeline/stages/01-commit-stage/scripts/run-integration-tests.mjs",
    "acceptance": "node scripts/acceptance.mjs",
    "acceptance:api": "tsx tests/acceptance/api/thread-lifecycle.ts",
    "acceptance:web": "playwright test tests/acceptance/web --config tests/acceptance/web/playwright.config.ts --reporter=line --workers=1",
    "acceptance:desktop": "tsx tests/acceptance/desktop/smoke.ts",
    "bootstrap:entra": "node platform/scripts/bootstrap/ensure-entra-apps.mjs",
    "bootstrap:github:check": "node platform/scripts/bootstrap/configure-github-repo.mjs --check",
    "bootstrap:github:apply": "node platform/scripts/bootstrap/configure-github-repo.mjs --apply",
    "bootstrap:apps": "node platform/scripts/bootstrap/bootstrap-production-apps.mjs",
    "infra:whatif": "node platform/scripts/infra/apply-platform.mjs --mode what-if",
    "infra:apply": "node platform/scripts/infra/apply-platform.mjs --mode apply"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.58.2",
    "@types/node": "24.10.13",
    "@vitest/coverage-v8": "3.2.4",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "eslint": "10.0.1",
    "eslint-config-prettier": "10.1.8",
    "jsdom": "^27.2.0",
    "jscpd": "^4.0.5",
    "madge": "^8.0.0",
    "node-pg-migrate": "8.0.4",
    "pg": "^8.16.3",
    "playwright": "1.58.2",
    "prettier": "3.8.1",
    "rimraf": "6.1.3",
    "tsx": "4.21.0",
    "turbo": "2.8.10",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.0",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "3.2.4"
  }
}
