{
  "name": "@compass/app-shell",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist-types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist-types/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist-types/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint . --ext .ts,.tsx --max-warnings=0",
    "test": "vitest run --config vitest.config.mts --passWithNoTests",
    "typecheck": "pnpm exec tsc -b ../contracts/tsconfig.ref.json ../sdk/tsconfig.ref.json ../shared/tsconfig.ref.json ../ui/tsconfig.ref.json tsconfig.ref.json"
  },
  "dependencies": {
    "@assistant-ui/react": "^0.12.14",
    "@assistant-ui/react-markdown": "^0.12.5",
    "@assistant-ui/react-ui": "^0.2.1",
    "@compass/contracts": "workspace:*",
    "@compass/sdk": "workspace:*",
    "@compass/shared": "workspace:*",
    "@compass/ui": "workspace:*",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-router/node": "7.12.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.542.0",
    "mermaid": "^11.12.3",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.6.5",
    "react-router": "7.12.0",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.3.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@react-router/dev": "7.12.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "vite": "^7.1.5"
  }
}
