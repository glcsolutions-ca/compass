{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "rootDir": "src",
    "outDir": "dist-types",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "types": ["node", "vite/client"],
    "baseUrl": ".",
    "paths": {
      "~/*": ["./src/*"],
      "@compass/client-app": ["./src/index.ts"],
      "@compass/client-app/*": ["./src/*"],
      "@compass/contracts": ["../contracts/src/index.ts"],
      "@compass/sdk": ["../sdk/src/index.ts"],
      "@compass/shared": ["../shared/src/index.ts"],
      "@compass/shared/*": ["../shared/src/*"],
      "@compass/ui": ["../ui/src/index.ts"],
      "@compass/ui/*": ["../ui/src/*"]
    }
  },
  "references": [
    {
      "path": "../contracts"
    },
    {
      "path": "../sdk"
    },
    {
      "path": "../shared"
    },
    {
      "path": "../ui"
    }
  ],
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
