{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "dist-types",
    "paths": {
      "~/*": ["./src/*"],
      "@compass/client-app": ["./src/index.ts"],
      "@compass/client-app/*": ["./src/*"]
    }
  },
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx"]
}
