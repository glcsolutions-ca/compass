{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://compass/pipeline/contracts/schemas/acceptance-evidence.schema.json",
  "title": "Acceptance Evidence Contract v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "candidateId",
    "sourceRevision",
    "workflowRunId",
    "environment",
    "verdict",
    "startedAt",
    "finishedAt",
    "summary"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "acceptance-evidence.v1"
    },
    "candidateId": {
      "type": "string",
      "pattern": "^sha-[a-f0-9]{40}$"
    },
    "sourceRevision": {
      "type": "string",
      "pattern": "^[a-f0-9]{40}$"
    },
    "workflowRunId": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 1
        },
        {
          "type": "string",
          "pattern": "^[0-9]+$"
        }
      ]
    },
    "environment": {
      "type": "string",
      "const": "acceptance"
    },
    "verdict": {
      "type": "string",
      "enum": ["pass", "fail"]
    },
    "startedAt": {
      "type": "string",
      "format": "date-time"
    },
    "finishedAt": {
      "type": "string",
      "format": "date-time"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    }
  }
}
