{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://compass/pipeline/contracts/schemas/production-rehearsal-evidence.schema.json",
  "title": "Production Rehearsal Evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "candidateId",
    "sourceRevision",
    "workflowRunId",
    "rehearsedAt",
    "verdict",
    "environment",
    "activeLabel",
    "inactiveLabel",
    "apiBaseUrl",
    "webBaseUrl",
    "apiRevision",
    "webRevision",
    "summary"
  ],
  "properties": {
    "schemaVersion": {
      "const": "production-rehearsal-evidence.v1"
    },
    "candidateId": {
      "type": "string",
      "pattern": "^sha-[a-f0-9]{40}$"
    },
    "sourceRevision": {
      "type": "string",
      "pattern": "^[a-f0-9]{40}$"
    },
    "workflowRunId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "rehearsedAt": {
      "type": "string",
      "format": "date-time"
    },
    "verdict": {
      "type": "string",
      "enum": ["pass", "fail"]
    },
    "environment": {
      "type": "string",
      "const": "production-rehearsal"
    },
    "activeLabel": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "inactiveLabel": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "apiBaseUrl": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500,
      "format": "uri"
    },
    "webBaseUrl": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500,
      "format": "uri"
    },
    "apiRevision": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "webRevision": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000
    }
  }
}
