{
  "name": "@compass/pipeline-tools",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run stages/shared-tests/validate-release-candidate.test.mjs stages/shared-tests/validate-release-candidate-runtime.test.mjs stages/shared-tests/cli-utils.test.mjs stages/shared-tests/fetch-release-candidate.test.mjs stages/shared-tests/schema-parity.test.mjs stages/shared-tests/build-candidate-id.test.mjs stages/01-commit/tests/generate-release-candidate.test.mjs stages/01-commit/tests/generate-commit-analysis-report.test.mjs stages/02-acceptance/tests/generate-acceptance-attestation-predicate.test.mjs stages/03-release/tests/verify-acceptance-attestation.test.mjs stages/03-release/tests/generate-release-attestation-predicate.test.mjs --silent=passed-only --reporter=dot",
    "analysis": "node stages/01-commit/scripts/check-complexity.mjs && node stages/01-commit/scripts/check-dependency-cycles.mjs && node stages/01-commit/scripts/generate-commit-analysis-report.mjs",
    "manifest:validate": "node shared/scripts/validate-release-candidate.mjs",
    "manifest:validate:runtime": "node shared/scripts/validate-release-candidate-runtime.mjs",
    "manifest:generate": "node stages/01-commit/scripts/generate-release-candidate.mjs",
    "manifest:fetch": "node shared/scripts/fetch-release-candidate.mjs",
    "attest:verify-acceptance": "node stages/03-release/scripts/verify-acceptance-attestation.mjs",
    "env:assert": "node shared/scripts/assert-environment-config.mjs",
    "acceptance:predicate:generate": "node stages/02-acceptance/scripts/generate-acceptance-attestation-predicate.mjs",
    "release:predicate:generate": "node stages/03-release/scripts/generate-release-attestation-predicate.mjs"
  }
}
